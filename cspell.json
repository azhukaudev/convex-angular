{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "useGitignore": true,
  "ignoreRegExpList": ["/%[0-9A-Fa-f]{2}[A-Za-z0-9%]*/g"],
  "ignorePaths": [
    ".git",
    ".angular",
    ".nx",
    ".worktrees",
    "coverage",
    "dist",
    "node_modules",
    "tmp",
    "pnpm-lock.yaml",
    "apps/frontend/src/convex/_generated/**"
  ],
  "words": [
    "AGENTS",
    "Aliaksandr",
    "Auth0",
    "Convex",
    "Zhukau",
    "cursorrules",
    "Prewarm",
    "Primeng",
    "cspell",
    "devkit",
    "dupcheck",
    "ianvs",
    "inputnumber",
    "inputtext",
    "jscpd",
    "knip",
    "lifecycles",
    "maxage",
    "ng",
    "npmjs",
    "packagr",
    "prewarm",
    "primeicons",
    "primeui",
    "primeuix",
    "progressspinner",
    "reauthentication",
    "reauthenticating",
    "refetches",
    "rethrowing",
    "tsconfig",
    "typechecks",
    "worktrees"
  ]
}
